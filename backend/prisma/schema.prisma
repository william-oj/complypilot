// Prisma schema for ComplyPilot (ISO-Easy)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  legalName   String?
  industry    String?
  size        String?
  country     String?
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      OrganizationMember[]
  roles        Role[]
  assets       Asset[]
  risks        Risk[]
  treatments   RiskTreatment[]
  controls     ControlImplementation[]
  policies     Policy[]
  evidence     Evidence[]
  audits       Audit[]
  auditLogs    AuditLog[]
  badges       BadgeUnlock[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  status        String   @default("INVITED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   OrganizationMember[]
  sessions      UserSession[]
  badges        BadgeUnlock[]
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizationMember {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  roleId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
}

model Role {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  members      OrganizationMember[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Asset {
  id              String             @id @default(uuid())
  orgId           String
  name            String
  type            String
  owner           String?
  location        String?
  classification  String             @default("INTERNAL")
  criticality     Int               @default(3)
  confidentiality Int               @default(3)
  integrity       Int               @default(3)
  availability    Int               @default(3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  risks        Risk[]

  @@index([orgId])
}

model Risk {
  id           String   @id @default(uuid())
  orgId        String
  assetId      String?
  title        String
  description  String?
  likelihood   Int
  impact       Int
  score        Int
  status       String   @default("OPEN")
  owner        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        Asset?        @relation(fields: [assetId], references: [id])
  treatments   RiskTreatment[]
  evidence     Evidence[]

  @@index([orgId])
  @@index([assetId])
}

model RiskTreatment {
  id           String           @id @default(uuid())
  orgId        String
  riskId       String
  treatment    String
  plan         String?
  owner        String?
  targetDate   DateTime?
  status       String?          
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  risk         Risk         @relation(fields: [riskId], references: [id], onDelete: Cascade)
  controls     RiskTreatmentControl[]

  @@index([orgId])
  @@index([riskId])
}

model Control {
  id          String   @id @default(uuid())
  controlId   String   @unique
  title       String
  description String
  guidance    String?
  category    String
  theme       String
  evidenceExamples String?

  implementations ControlImplementation[]
  treatmentLinks   RiskTreatmentControl[]
  auditFindings    AuditFinding[]
}

model ControlImplementation {
  id          String   @id @default(uuid())
  orgId       String
  controlId   String
  status      String   @default("NOT_STARTED")
  owner       String?
  notes       String?
  implementedAt DateTime?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  evidence     Evidence[]

  @@unique([orgId, controlId])
  @@index([orgId])
}

model RiskTreatmentControl {
  id            String @id @default(uuid())
  treatmentId   String
  controlId     String

  treatment RiskTreatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  control   Control       @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@unique([treatmentId, controlId])
}

model PolicyTemplate {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  template    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policies Policy[]
}

model Policy {
  id          String   @id @default(uuid())
  orgId       String
  templateId  String
  title       String
  content     String
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template     PolicyTemplate @relation(fields: [templateId], references: [id])

  @@index([orgId])
}

model Evidence {
  id           String   @id @default(uuid())
  orgId        String
  controlImplementationId String?
  riskId       String?
  type         String   @default("OTHER")
  title        String
  description  String?
  fileKey      String
  fileUrl      String
  uploadedBy   String?
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  controlImplementation ControlImplementation? @relation(fields: [controlImplementationId], references: [id])
  risk         Risk? @relation(fields: [riskId], references: [id])

  @@index([orgId])
}

model Audit {
  id          String   @id @default(uuid())
  orgId       String
  title       String
  scope       String?
  scheduledAt DateTime?
  status      String   @default("PLANNED")
  auditor     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  findings     AuditFinding[]

  @@index([orgId])
}

model AuditFinding {
  id          String   @id @default(uuid())
  auditId     String
  controlId   String?
  severity    String   @default("MEDIUM")
  title       String
  description String?
  status      String? 
  createdAt   DateTime @default(now())

  audit   Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  control Control? @relation(fields: [controlId], references: [id])
  actions CorrectiveAction[]

  @@index([auditId])
}

model CorrectiveAction {
  id          String   @id @default(uuid())
  findingId   String
  owner       String?
  action      String
  dueDate     DateTime?
  status      String?
  createdAt   DateTime @default(now())

  finding AuditFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  target    String?
  metadata  String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Badge {
  id          String   @id @default(uuid())
  type        String   @unique
  name        String
  description String?

  unlocks     BadgeUnlock[]
}

model BadgeUnlock {
  id          String   @id @default(uuid())
  orgId       String
  userId      String
  badgeId     String
  unlockedAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge        Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, badgeId])
}
